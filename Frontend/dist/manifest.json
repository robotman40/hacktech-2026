{
  "manifest_version": 3,
  "name": "Messaging Safety Check",
  "version": "1.0.0",
  "description": "Scans the selected messaging site for potentially manipulative or malicious text",
  "action": {
    "default_title": "Messaging Safety Check",
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
